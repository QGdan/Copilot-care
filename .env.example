# Global provider fallback (none|auto|deepseek|gemini|kimi|deepseek_gemini|openai|anthropic)
COPILOT_CARE_LLM_PROVIDER=auto

# Runtime retry/timeout
COPILOT_CARE_LLM_TIMEOUT_MS=12000
COPILOT_CARE_LLM_MAX_RETRIES=1
COPILOT_CARE_LLM_RETRY_DELAY_MS=300

# Role-based provider split
COPILOT_CARE_CARDIO_PROVIDER=deepseek
COPILOT_CARE_GP_PROVIDER=gemini
COPILOT_CARE_METABOLIC_PROVIDER=gemini
COPILOT_CARE_SAFETY_PROVIDER=kimi

# Provider API keys (fill your own keys, never commit real secrets)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider model names
DEEPSEEK_LLM_MODEL=deepseek-chat
GEMINI_LLM_MODEL=gemini-2.5-flash
KIMI_LLM_MODEL=moonshot-v1-8k
OPENAI_LLM_MODEL=gpt-5-mini
ANTHROPIC_LLM_MODEL=claude-sonnet-4-5

# Optional base URLs
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KIMI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Backend port (keep in sync with VITE_API_BASE_URL)
APP_PORT=3001

# Frontend API options
VITE_API_BASE_URL=http://localhost:3001
VITE_API_TIMEOUT_MS=120000
