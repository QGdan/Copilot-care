# Global provider fallback (none|auto|deepseek|gemini|kimi|dashscope|deepseek_gemini|openai|anthropic)
COPILOT_CARE_LLM_PROVIDER=auto
# Optional auto fallback order when COPILOT_CARE_LLM_PROVIDER=auto
# COPILOT_CARE_LLM_AUTO_CHAIN=dashscope,kimi,deepseek,gemini,openai,anthropic

# Runtime retry/timeout
COPILOT_CARE_LLM_TIMEOUT_MS=12000
COPILOT_CARE_LLM_MAX_RETRIES=1
COPILOT_CARE_LLM_RETRY_DELAY_MS=300

# Role-based provider split
COPILOT_CARE_CARDIO_PROVIDER=deepseek
COPILOT_CARE_GP_PROVIDER=gemini
COPILOT_CARE_METABOLIC_PROVIDER=gemini
COPILOT_CARE_SAFETY_PROVIDER=kimi

# Provider API keys (fill your own keys, never commit real secrets)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider model names
DEEPSEEK_LLM_MODEL=deepseek-chat
GEMINI_LLM_MODEL=gemini-2.5-flash
KIMI_LLM_MODEL=moonshot-v1-8k
DASHSCOPE_LLM_MODEL=qwen-plus
OPENAI_LLM_MODEL=gpt-5-mini
ANTHROPIC_LLM_MODEL=claude-sonnet-4-5

# Optional multi-model panel fan-out (provider or provider:model; comma/space/|/> separated)
# COPILOT_CARE_CARDIO_PANEL_PROVIDERS=deepseek,gemini,dashscope:qwen-plus,dashscope:qwen-max
# COPILOT_CARE_GP_PANEL_PROVIDERS=gemini,dashscope:qwen-plus
# COPILOT_CARE_METABOLIC_PANEL_PROVIDERS=gemini,dashscope:qwen-plus

# Optional base URLs
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KIMI_BASE_URL=https://api.moonshot.cn/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Backend port (keep in sync with VITE_API_BASE_URL)
APP_PORT=3001

# Frontend API options
VITE_API_BASE_URL=http://localhost:3001
VITE_API_TIMEOUT_MS=120000

# Optional static frontend path used by backend in single-service deployment
COPILOT_CARE_FRONTEND_DIST=src/frontend/dist

# Runtime state backend
# memory: process-local only
# file: restore idempotency and governance state after restart on the same disk
COPILOT_CARE_RUNTIME_STATE_BACKEND=memory
COPILOT_CARE_RUNTIME_STATE_DIR=reports/runtime/state

# Production exposure controls
# In production, demo consent is always disabled.
COPILOT_CARE_CONSENT_TOKEN_ALLOWLIST=
COPILOT_CARE_CORS_ALLOWED_ORIGINS=
COPILOT_CARE_REQUIRE_TRIAGE_AUTH=true
COPILOT_CARE_TRIAGE_API_KEY=

# Interop/MCP are enabled by default outside production and disabled by default in production.
COPILOT_CARE_ENABLE_INTEROP=false
COPILOT_CARE_INTEROP_API_KEY=
COPILOT_CARE_INTEROP_JOB_MAX_RETRIES=2
COPILOT_CARE_INTEROP_JOB_RETRY_DELAY_MS=300
# for local verification only: none | fail_once | fail_always
COPILOT_CARE_INTEROP_JOB_SIMULATION=none
COPILOT_CARE_INTEROP_WRITEBACK_MODE=mock
COPILOT_CARE_INTEROP_FHIR_BASE_URL=
COPILOT_CARE_INTEROP_FHIR_BUNDLE_PATH=/Bundle
COPILOT_CARE_INTEROP_FHIR_AUTH_TOKEN=
COPILOT_CARE_INTEROP_REAL_TIMEOUT_MS=8000
COPILOT_CARE_INTEROP_AUDIT_LOG_ENABLED=true
COPILOT_CARE_INTEROP_AUDIT_LOG_FILE=reports/runtime/interop-writeback.runtime.jsonl

# SMART introspection (recommended for production interop)
COPILOT_CARE_SMART_INTROSPECTION_ENABLED=false
COPILOT_CARE_SMART_INTROSPECTION_URL=
COPILOT_CARE_SMART_INTROSPECTION_CLIENT_ID=
COPILOT_CARE_SMART_INTROSPECTION_CLIENT_SECRET=
COPILOT_CARE_SMART_INTROSPECTION_TIMEOUT_MS=5000
COPILOT_CARE_SMART_INTROSPECTION_CACHE_TTL_MS=10000
COPILOT_CARE_SMART_REQUIRED_AUDIENCE=
COPILOT_CARE_SMART_REQUIRED_ISSUER=
# In production, recommend false to force introspection scope as source of truth
COPILOT_CARE_SMART_SCOPE_HEADER_FALLBACK=true
COPILOT_CARE_ENABLE_MCP=false
COPILOT_CARE_MCP_API_KEY=
COPILOT_CARE_MCP_BASE_URL=
COPILOT_CARE_MCP_TIMEOUT_MS=30000
COPILOT_CARE_MCP_MAX_RETRIES=0
COPILOT_CARE_MCP_RETRY_DELAY_MS=200

# Authoritative medical web search (restricted to curated domain whitelist)
COPILOT_CARE_MED_SEARCH_ENABLED=true
COPILOT_CARE_MED_SEARCH_TIMEOUT_MS=8000
COPILOT_CARE_MED_SEARCH_MAX_RESULTS=8
COPILOT_CARE_MED_SEARCH_PUBMED_RETMAX=6
COPILOT_CARE_MED_SEARCH_DDG_ENABLED=true

# false: do not fill from static seed list when live results are missing
# true: allow seed list fallback when live results are insufficient
COPILOT_CARE_MED_SEARCH_ALLOW_PARTIAL_SEED_FILL=false

# Search cache controls (milliseconds + max entries); set TTL=0 to disable cache
COPILOT_CARE_MED_SEARCH_CACHE_TTL_MS=180000
COPILOT_CARE_MED_SEARCH_CACHE_MAX_ENTRIES=128

# Provider circuit-breaker controls
COPILOT_CARE_MED_SEARCH_PROVIDER_FAILURE_THRESHOLD=3
COPILOT_CARE_MED_SEARCH_PROVIDER_CIRCUIT_OPEN_MS=60000
COPILOT_CARE_MED_SEARCH_IN_TRIAGE=true
COPILOT_CARE_MED_SEARCH_HYBRID_RETRIEVER_ENABLED=true
