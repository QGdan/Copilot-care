{
  "name": "@copilot-care/backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build --prefix ../shared && node scripts/clean-dist.cjs && tsc -p tsconfig.json && node scripts/check-dist-hygiene.cjs",
    "typecheck": "npm run build --prefix ../shared && tsc --noEmit -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "test": "npm run build --prefix ../shared && jest --config jest.config.cjs"
  },
  "dependencies": {
    "@copilot-care/shared": "1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
